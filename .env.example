# GitHub OAuth
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub Personal Access Token
# Create a fine-grained token with access to the content repository.
GITHUB_TOKEN=your_github_token_here

# AI service, optional. Used for smart project descriptions during GitHub repo import.
ZHIPU_API_KEY=your_zhipu_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public GitHub repository used by the public site.
PUBLIC_GITHUB_REPO=yourusername/your-repo
PUBLIC_GITHUB_BRANCH=main
